# API Configuration
OPENAI_API_KEY=your_openai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
# DEEPSEEK_API_KEY is required for default cheap_api profile.
# OPENAI_API_KEY is optional (only needed if you add vision_analysis role).
# ANY_LLM_API_KEY is optional (only needed if you use any_llm provider).
# See config/shigoku.yaml llm section for role/profile/provider configuration.

# Tracing
CAI_TRACING=false

# RAG Configuration
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
CHROMA_HOST=localhost
CHROMA_PORT=8001

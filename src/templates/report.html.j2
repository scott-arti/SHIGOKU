<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ finding.title }}</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
            line-height: 1.6;
        }
        h1 { color: #333; border-bottom: 2px solid {{ severity_color }}; padding-bottom: 10px; }
        h2 { color: #444; margin-top: 30px; }
        h3 { color: #555; }
        pre { background: #f4f4f4; padding: 15px; border-radius: 5px; overflow-x: auto; }
        code { background: #f4f4f4; padding: 2px 5px; border-radius: 3px; }
        .severity-badge {
            display: inline-block;
            background: {{ severity_color }};
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: bold;
        }
        .meta { color: #666; font-size: 0.9em; }
        li { margin: 5px 0; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; }
    </style>
</head>
<body>
    <div class="severity-badge">{{ finding.severity.value.upper() }}</div>
    
    <h1>{{ finding.title }}</h1>
    
    <p class="meta">
        <strong>Target:</strong> {{ finding.target_url }} | 
        <strong>Discovered:</strong> {{ finding.discovered_at.strftime('%Y-%m-%d %H:%M:%S') }} |
        <strong>Agent:</strong> {{ finding.source_agent }}
    </p>
    
    <h2>Summary</h2>
    <p>{{ finding.description | nl2br }}</p>

    <h2>Vulnerability Type</h2>
    <ul>
        <li><strong>Type:</strong> {{ vuln_info.get('title', finding.vuln_type.value) }}</li>
        <li><strong>Category:</strong> {{ vuln_info.get('category', 'Other') }}</li>
        {% if finding.cwe_id %}
        <li><strong>CWE:</strong> <a href="https://cwe.mitre.org/data/definitions/{{ finding.cwe_id.split('-')[1] }}.html">{{ finding.cwe_id }}</a></li>
        {% endif %}
    </ul>

    <h2>Severity</h2>
    <p><strong>{{ finding.severity.value.upper() }}</strong> (CVSS: {{ cvss_range }})</p>
    {% if finding.cvss_score %}
    <p>Calculated CVSS: {{ finding.cvss_score }}</p>
    {% endif %}

    <h2>Steps to Reproduce</h2>
    <ul>
    {% for step in finding.reproduction_steps %}
        <li>{{ step }}</li>
    {% endfor %}
    </ul>

    <h2>Impact</h2>
    <p>{{ finding.impact | nl2br }}</p>

    {% if finding.evidence %}
    <h2>Proof of Concept</h2>
    <pre><code>{{ finding.evidence.to_markdown() }}</code></pre>

    <h3>Reproduction Commands</h3>
    <p><strong>cURL:</strong></p>
    <pre><code>{{ curl_cmd }}</code></pre>
    {% endif %}

    <h2>Remediation</h2>
    <p>{{ remediation | nl2br }}</p>

    <hr>
    <p class="meta">
        Generated by SHIGOKU | {{ now }}
    </p>

</body>
</html>
